generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  image       String
  price       Float
  category    String
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  events    EventLog[]
}

model EventLog {
  id          String   @id @default(cuid())
  sessionId   String
  type        String
  productId   String?
  variantId   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])
}

model Experiment {
  id          String    @id @default(cuid())
  name        String
  status      String
  createdAt   DateTime  @default(now())
  variants    Variant[]
}

model Variant {
  id             String   @id @default(cuid())
  experimentId   String
  label          String
  weight         Float    @default(1)
  confidence     Float    @default(50)
  conversions    Int      @default(0)
  impressions    Int      @default(0)

  experiment Experiment @relation(fields: [experimentId], references: [id])
}

model Decision {
  id            String   @id @default(cuid())
  experimentId  String
  selectedLabel String
  confidence    Float
  reasoning     String
  createdAt     DateTime @default(now())
}

model Outcome {
  id          String   @id @default(cuid())
  decisionId  String
  success     Boolean
  score       Float
  createdAt   DateTime @default(now())
}
